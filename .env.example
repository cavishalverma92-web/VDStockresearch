# -----------------------------------------------------------------------------
# Environment configuration template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in values as needed.
#   macOS/Linux:   cp .env.example .env
#   Windows (cmd): copy .env.example .env
#
# NEVER commit `.env` to Git. It is already in `.gitignore`.
# -----------------------------------------------------------------------------

# ---- App ----
APP_ENV=development                 # development | staging | production
APP_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
APP_TIMEZONE=Asia/Kolkata

# ---- Streamlit ----
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=false

# ---- Database ----
# For Phase 0, SQLite is acceptable as a learning bridge.
# Target for all later phases: PostgreSQL.
DATABASE_URL=sqlite:///data/stock_platform.db
# Example Postgres URL (uncomment and fill when ready):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/stock_platform

# ---- Data provider toggles (Phase 0 uses yfinance only) ----
PROVIDER_PRICE=yfinance             # yfinance | kite | dhan | fyers | upstox
MARKET_DATA_PROVIDER=kite           # kite | yfinance | auto
PROVIDER_FUNDAMENTALS=local_csv     # local_csv | none | screener | trendlyne | tijori
FUNDAMENTALS_CSV_PATH=data/sample/fundamentals_annual_sample.csv

# ---- Broker / vendor API keys (leave blank until you actually need them) ----
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
ENABLE_KITE_MARKET_DATA=true
ENABLE_KITE_TRADING=false
ENABLE_KITE_PORTFOLIO=false
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# ---- LLM (Phase 6+ only — not needed for MVP) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Alerts (Phase 6) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ---- Cache & rate limits ----
CACHE_DIR=data/cache
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
HTTP_RATE_LIMIT_PER_SEC=2
HTTP_TIMEOUT_SEC=30
